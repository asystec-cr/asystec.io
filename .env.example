# Optional public identifiers for consent-gated campaign measurement.
# Leave blank to keep each integration disabled. Never put access tokens or API secrets here.
# Configure the GTM container so tags never read or send form values or other personal data.
# If Meta Pixel is deployed inside GTM, leave NEXT_PUBLIC_META_PIXEL_ID blank to avoid duplicate events.
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_META_PIXEL_ID=
